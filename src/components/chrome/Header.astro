---
const navItems = [
  {
    label: 'Programs',
    href: null,
    children: [
      { label: 'For universities', href: '/for-universities' },
      { label: 'For organizations', href: '/for-organizations' },
    ],
  },
  { label: 'Research', href: '/research' },
  { label: 'Advisory board', href: '/advisory-board' },
  { label: 'Insights', href: '/insights' },
  { label: 'Contact', href: '/contact' },
];

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) => path === href || path.startsWith(href + '/');
---

<header class="bg-ink text-paper border-b border-ink-soft sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center gap-3" aria-label="ZAI Institute, home">
        <svg width="32" height="32" viewBox="0 0 100 100" aria-hidden="true" focusable="false">
          <rect x="0" y="0" width="100" height="100" fill="#0A0A0F" />
          <rect x="4" y="4" width="92" height="92" fill="none" stroke="#B8962E" stroke-width="2.5" />
          <path
            d="M 22 22 L 78 22 L 22 78 L 78 78"
            fill="none"
            stroke="#F5F2ED"
            stroke-width="6"
            stroke-linejoin="miter"
            stroke-linecap="square"
          />
          <circle cx="89" cy="11" r="4" fill="#B8962E" />
          <circle cx="11" cy="89" r="4" fill="#B8962E" />
        </svg>
        <span class="flex items-baseline gap-2">
          <span class="font-display text-xl text-gold leading-none">ZAI</span>
          <span class="h-4 w-px bg-gold/60" aria-hidden="true"></span>
          <span class="font-sans text-[0.7rem] tracking-[0.22em] uppercase text-paper">Institute</span>
        </span>
      </a>

      <nav aria-label="Primary" class="hidden md:flex items-center gap-8">
        {
          navItems.map((item) =>
            item.children ? (
              <details class="relative group">
                <summary
                  class="list-none cursor-pointer text-sm font-medium text-paper hover:text-gold-light transition-colors flex items-center gap-1"
                  aria-haspopup="true"
                >
                  {item.label}
                  <svg width="10" height="10" viewBox="0 0 10 10" aria-hidden="true" class="opacity-70">
                    <path d="M1 3 L5 7 L9 3" fill="none" stroke="currentColor" stroke-width="1.5" />
                  </svg>
                </summary>
                <ul
                  role="menu"
                  class="absolute left-0 top-full mt-2 min-w-[15rem] bg-ink border border-ink-soft py-2"
                >
                  {item.children.map((child) => (
                    <li role="none">
                      <a
                        role="menuitem"
                        href={child.href}
                        class={`block px-4 py-2 text-sm hover:bg-ink-soft hover:text-gold-light transition-colors ${
                          isActive(child.href) ? 'text-gold' : 'text-paper'
                        }`}
                      >
                        {child.label}
                      </a>
                    </li>
                  ))}
                </ul>
              </details>
            ) : (
              <a
                href={item.href!}
                class={`text-sm font-medium transition-colors hover:text-gold-light ${
                  isActive(item.href!) ? 'text-gold' : 'text-paper'
                }`}
              >
                {item.label}
              </a>
            )
          )
        }
      </nav>

      <button
        id="menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden text-paper p-2 -mr-2"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="1.5" />
        </svg>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="mobile-menu md:hidden fixed inset-0 top-16 bg-ink z-40 flex-col"
    aria-hidden="true"
  >
    <nav aria-label="Mobile primary" class="flex flex-col p-6 gap-4 border-t border-ink-soft">
      <div>
        <div class="eyebrow mb-3">Programs</div>
        <a href="/for-universities" class="block py-2 text-paper text-lg hover:text-gold-light">
          For universities
        </a>
        <a href="/for-organizations" class="block py-2 text-paper text-lg hover:text-gold-light">
          For organizations
        </a>
      </div>
      <hr class="rule-muted" />
      <a href="/research" class="py-2 text-paper text-lg hover:text-gold-light">Research</a>
      <a href="/advisory-board" class="py-2 text-paper text-lg hover:text-gold-light">Advisory board</a>
      <a href="/insights" class="py-2 text-paper text-lg hover:text-gold-light">Insights</a>
      <a href="/contact" class="py-2 text-paper text-lg hover:text-gold-light">Contact</a>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  if (toggle && menu) {
    toggle.addEventListener('click', () => {
      const open = document.body.classList.toggle('menu-open');
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.setAttribute('aria-hidden', String(!open));
    });
    document.querySelectorAll('#mobile-menu a').forEach((a) => {
      a.addEventListener('click', () => {
        document.body.classList.remove('menu-open');
        toggle.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
      });
    });
  }
</script>
