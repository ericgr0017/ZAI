---
export interface Props {
  label: string;
  note?: string;
}
const { label, note } = Astro.props;
---

<div
  class="border border-dashed border-muted/50 bg-paper/60 px-5 py-4 my-4 max-w-prose-wide font-sans italic text-slate"
  role="note"
  aria-label="Placeholder content for review"
>
  <div class="font-mono not-italic text-xs uppercase tracking-wide-cap text-muted mb-1">
    Placeholder
  </div>
  <div class="text-base leading-relaxed">{label}</div>
  {note && <div class="text-xs not-italic text-muted mt-2 font-mono">{note}</div>}
</div>
