---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/ui/SectionHero.astro';
import Placeholder from '@components/ui/Placeholder.astro';
---

<BaseLayout
  title="For organizations"
  description="ZAI Institute partners with enterprises to deliver workforce AI training, executive workshops, and custom curriculum, with access to a network of 50,000 senior operators."
>
  <SectionHero
    eyebrow="For organizations"
    title="AI training for the people who run the work."
    lede="Placeholder lede for enterprise training buyers. CLOs, heads of L&D, transformation leaders."
  />

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24 space-y-16">
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Workforce AI training</div>
        <Placeholder label="Broad-audience training programs. Format, depth, typical cohort size, typical engagement length." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Executive workshops</div>
        <Placeholder label="Senior-leader workshops. Half-day, day, multi-day formats. Topics and outcomes." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Custom curriculum</div>
        <Placeholder label="How ZAI builds curriculum tailored to an organization's sector and workflow." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Advisory network access</div>
        <Placeholder label="How senior leadership at partner organizations engages the 50K-executive advisory network." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Outcomes</div>
        <Placeholder label="What organizations typically see from the partnership. Capability uplift, project velocity, internal community." />
      </div>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-prose-wide">
        <div class="eyebrow mb-6">Next step</div>
        <h2 class="font-display text-h2 text-paper">
          A discovery conversation.
        </h2>
        <p class="mt-6 text-body-lg text-paper/85">
          <Placeholder label="One sentence framing the discovery call for enterprise buyers." />
        </p>
        <div class="mt-10">
          <a href="/contact" class="btn btn-primary">Request a discovery conversation</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
