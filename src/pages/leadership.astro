---
import BaseLayout from '@layouts/BaseLayout.astro';
import advisors from '../data/advisors.json';

const { chair, members } = advisors;
---

<BaseLayout
  title="Leadership & Advisory Network"
  description="Meet the academics, practitioners, and industry leaders who shape ZAI Institute programs delivered with more than 60 universities over the past decade."
>
  <Fragment slot="head">
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "@id": "https://zaiinstitute.ai/#organization",
      "name": "ZAI Institute",
      "url": "https://zaiinstitute.ai",
      "description": "ZAI Institute has partnered with more than 60 universities over the past decade to deploy AI executive education programs under university brands in 30 days.",
      "founder": {
        "@type": "Person",
        "name": "Eric Greenberg",
        "jobTitle": "Founder & CEO",
        "worksFor": { "@type": "EducationalOrganization", "name": "ZAI Institute" },
        "alumniOf": [
          { "@type": "CollegeOrUniversity", "name": "The Wharton School, University of Pennsylvania" },
          { "@type": "CollegeOrUniversity", "name": "NYU School of Law" }
        ],
        "knowsAbout": ["Artificial Intelligence", "Executive Education", "University Partnerships", "Digital Marketing Strategy"],
        "description": "Author of Strategic AI and Strategic Digital Marketing (McGraw-Hill). Built university-industry partnership models across 60+ institutions."
      }
    }
    </script>
  </Fragment>

  <!-- HERO -->
  <section class="hero">
    <div class="hero-glow"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-content">
      <p class="hero-eyebrow">Leadership &amp; Advisory Network</p>
      <h1>Academics, practitioners, and industry leaders <em>building the future of education together.</em></h1>
      <p class="hero-sub">ZAI programs are shaped by a network of executives, scholars, and practitioners from the world&rsquo;s leading organizations and universities. They guide curriculum, mentor participants, and connect learning to real-world impact.</p>
      <p class="hero-purpose" style="font-family: var(--serif); font-style: italic; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.3; color: var(--gold-light); margin-top: 28px;">We exist to turn intelligence into measurable progress.</p>
      <div class="hero-quote">
        <blockquote>&ldquo;The greatest untapped resource in education is not technology. It is the connection between university leadership and industry leadership.&rdquo;</blockquote>
        <cite>ZAI Institute Founding Principle</cite>
      </div>
    </div>
  </section>

  <!-- STATS BAR -->
  <div class="hero-stats">
    <div class="hero-stats-inner">
      <div class="stat-card"><div class="stat-number">6,000+</div><div class="stat-label">Advisors across university programs, past year</div></div>
      <div class="stat-card"><div class="stat-number">60+</div><div class="stat-label">Universities served, past decade</div></div>
      <div class="stat-card"><div class="stat-number">500+</div><div class="stat-label">Companies Represented</div></div>
    </div>
  </div>

  <!-- ADVISORY BOARD ROSTER -->
  <section class="grid-section">
    <div class="grid-intro">
      <p class="section-eyebrow">The Board</p>
      <h2 class="section-heading">The executives and academics <em>who advise the institute.</em></h2>
      <p>A board of named senior operators and academics advises the institute itself. They sit above the advisory boards that run across our university partner programs, guiding research direction, curriculum standards, capstone evaluation, and the connection between academic work and the employers who hire graduates.</p>
    </div>

    <div class="board-works">
      <p>The Advisory Board meets quarterly and contributes throughout the year through curriculum review, capstone evaluations, panel participation, and informal peer briefings with cohort participants.</p>
      <p>The Board does not approve research findings or program syllabi. It informs them. What the institute publishes is aggregated and de-identified. No finding is attributed to a member or their company by name.</p>
    </div>

    <div class="chair-block">
      <p class="roster-eyebrow">Chair</p>
      <div class="chair-card">
        <div class="roster-company">{chair.company}</div>
        <div class="chair-name">{chair.name}</div>
        <div class="roster-title">{chair.title}</div>
      </div>
    </div>

    <div class="members-block">
      <p class="roster-eyebrow">Members</p>
      <div class="roster-grid">
        {
          members.map((m) => (
            <div class="roster-card">
              <div class="roster-company">{m.company}</div>
              <div class="roster-name">{m.name}</div>
              <div class="roster-title">{m.title}</div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="join-board">
      <p class="section-eyebrow">Join the board</p>
      <p class="join-board-lede">Join the executives helping define what AI education should measure, teach, and prove. Benchmark with peers, shape the research, and see what leaders are actually doing with AI.</p>
      <a href="/contact/" class="btn-gold">Join our research network</a>
    </div>
  </section>

  <!-- NETWORK TICKER BAND -->
  <section class="network-band">
    <div class="network-band-inner">
      <p class="network-band-intro">Join a community of <strong>senior</strong> executives. More than <strong>6,000</strong> served on advisory boards across our university partner programs in the past year, at organizations including</p>
    </div>
    <div class="network-scroll">
      <div class="scroll-track">
          <span class="company-name">Accenture</span>
          <span class="company-name">Aetna</span>
          <span class="company-name">AIG</span>
          <span class="company-name">AT&amp;T</span>
          <span class="company-name">Bank of America</span>
          <span class="company-name">BlueCross BlueShield</span>
          <span class="company-name">Cigna</span>
          <span class="company-name">Comcast</span>
          <span class="company-name">Deloitte</span>
          <span class="company-name">Dow Jones</span>
          <span class="company-name">Est&eacute;e Lauder</span>
          <span class="company-name">Forbes</span>
          <span class="company-name">Intel</span>
          <span class="company-name">Johnson &amp; Johnson</span>
          <span class="company-name">Marriott</span>
          <span class="company-name">Mastercard</span>
          <span class="company-name">Merck</span>
          <span class="company-name">Microsoft</span>
          <span class="company-name">Morgan Stanley</span>
          <span class="company-name">Novartis</span>
          <span class="company-name">Prudential</span>
          <span class="company-name">Salesforce</span>
          <span class="company-name">JPMorgan Chase</span>
          <span class="company-name">Oracle</span>
          <span class="company-name">IBM</span>
          <span class="company-name">Adobe</span>
          <span class="company-name">Accenture</span>
          <span class="company-name">Aetna</span>
          <span class="company-name">AIG</span>
          <span class="company-name">AT&amp;T</span>
          <span class="company-name">Bank of America</span>
          <span class="company-name">BlueCross BlueShield</span>
          <span class="company-name">Cigna</span>
          <span class="company-name">Comcast</span>
          <span class="company-name">Deloitte</span>
          <span class="company-name">Dow Jones</span>
          <span class="company-name">Est&eacute;e Lauder</span>
          <span class="company-name">Forbes</span>
          <span class="company-name">Intel</span>
          <span class="company-name">Johnson &amp; Johnson</span>
          <span class="company-name">Marriott</span>
          <span class="company-name">Mastercard</span>
          <span class="company-name">Merck</span>
          <span class="company-name">Microsoft</span>
          <span class="company-name">Morgan Stanley</span>
          <span class="company-name">Novartis</span>
          <span class="company-name">Prudential</span>
          <span class="company-name">Salesforce</span>
          <span class="company-name">JPMorgan Chase</span>
          <span class="company-name">Oracle</span>
          <span class="company-name">IBM</span>
          <span class="company-name">Adobe</span>
          </div>
    </div>
    <div class="network-divider"></div>
    <div class="network-scroll">
      <div class="scroll-track reverse uni-track">
          <span class="company-name">UCLA</span>
          <span class="company-name">University of Miami</span>
          <span class="company-name">Seton Hall University</span>
          <span class="company-name">University of Colorado Colorado Springs</span>
          <span class="company-name">University of Minnesota Mankato</span>
          <span class="company-name">University of Richmond</span>
          <span class="company-name">Ohio State University</span>
          <span class="company-name">University of San Francisco</span>
          <span class="company-name">University of Colorado Boulder</span>
          <span class="company-name">UCLA</span>
          <span class="company-name">University of Miami</span>
          <span class="company-name">Seton Hall University</span>
          <span class="company-name">University of Colorado Colorado Springs</span>
          <span class="company-name">University of Minnesota Mankato</span>
          <span class="company-name">University of Richmond</span>
          <span class="company-name">Ohio State University</span>
          <span class="company-name">University of San Francisco</span>
          <span class="company-name">University of Colorado Boulder</span>
          </div>
    </div>
    <div class="network-band-inner">
      <p class="network-band-note">Advisory board members across 60+ university partner programs</p>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="cta-inner">
      <p class="section-eyebrow" style="color:var(--gold);">Begin the Conversation</p>
      <h2 class="section-heading">The institutions that move with intention <em>now</em> will define what comes next.</h2>
      <p class="cta-sub">Which side of that sentence does your institution want to be on?</p>
      <div class="cta-buttons">
        <a href="/contact/" class="btn-gold">Request a Partnership Conversation</a>
        <a href="/research/" class="btn-outline">Join the AI Readiness Study</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style is:global>
:root {
  --ink: #0A0A0F;
  --ink-soft: #1A1A2E;
  --gold: #B8962E;
  --gold-light: #D4AE4A;
  --gold-pale: #F5EDD4;
  --gold-accessible: #7D6415;      /* 5.1:1 on paper, 5.7:1 on white — WCAG AA */
  --gold-accessible-light: #886E1A; /* 4.9:1 on white — WCAG AA */
  --paper: #F5F2ED;
  --slate: #2C3E5A;
  --muted: #6B6B7A;
  --slate-deep: #1B2A40;
  --slate-mid: #3D5478;
  --slate-light: #5A7399;
  --teal: #1A5C6B;
  --teal-soft: #2A7A8A;
  --teal-pale: #E4F2F5;
  --warm: #8B5E3C;
  --warm-light: #C49A6C;
  --warm-pale: #F8F0E6;
  --sage: #4A6B5A;
  --sage-light: #6B8E7A;
  --serif: 'Cormorant Garamond', Georgia, serif;
  --sans: 'Inter', -apple-system, sans-serif;
  --mono: 'JetBrains Mono', 'Courier New', monospace;
  --section-pad: clamp(80px, 10vw, 140px);
}

/* Shared components */
.section-eyebrow {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.25em;
  color: var(--gold-accessible); text-transform: uppercase; margin-bottom: 16px;
}
.section-heading {
  font-family: var(--serif); font-size: clamp(32px, 4vw, 48px);
  font-weight: 400; line-height: 1.2; color: var(--ink); margin-bottom: 20px;
}
.section-heading em { font-style: italic; color: var(--slate); }
.btn-gold {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 32px;
  background: linear-gradient(135deg, var(--gold), var(--gold-light));
  color: var(--ink); font-family: var(--sans); font-size: 14px; font-weight: 600;
  text-decoration: none; letter-spacing: 0.02em; border: none; cursor: pointer;
  transition: transform 0.3s, box-shadow 0.3s;
}
.btn-gold:hover { transform: translateY(-2px); box-shadow: 0 8px 30px rgba(184,150,46,0.3); }
.btn-outline {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 14px 32px; background: transparent;
  border: 1px solid rgba(255,255,255,0.25);
  color: rgba(255,255,255,0.8); font-family: var(--sans); font-size: 14px; font-weight: 500;
  text-decoration: none; letter-spacing: 0.02em; cursor: pointer;
  transition: border-color 0.3s, color 0.3s;
}
.btn-outline:hover { border-color: var(--gold); color: var(--gold); }

/* ============================================================
   HERO — Leadership page version
   ============================================================ */
.hero {
  position: relative; min-height: 70vh;
  display: flex; align-items: center;
  background:
    radial-gradient(ellipse 80% 60% at 20% 80%, rgba(26, 92, 107, 0.25) 0%, transparent 60%),
    radial-gradient(ellipse 60% 50% at 80% 20%, rgba(44, 62, 90, 0.35) 0%, transparent 60%),
    radial-gradient(ellipse 90% 80% at 50% 50%, rgba(26, 26, 46, 0.9) 0%, rgba(10, 10, 15, 1) 70%);
  overflow: hidden;
}
.hero::before {
  content: '';
  position: absolute; inset: 0;
  background:
    repeating-linear-gradient(0deg, transparent, transparent 60px, rgba(184,150,46,0.03) 60px, rgba(184,150,46,0.03) 61px),
    repeating-linear-gradient(90deg, transparent, transparent 60px, rgba(184,150,46,0.03) 60px, rgba(184,150,46,0.03) 61px);
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute; bottom: 0; left: 0; right: 0; height: 200px;
  background: linear-gradient(to top, var(--paper), transparent);
  pointer-events: none;
}
.hero-glow {
  position: absolute; top: -100px; right: -100px;
  width: 600px; height: 600px;
  background: radial-gradient(circle, rgba(184,150,46,0.12) 0%, transparent 70%);
  border-radius: 50%;
  animation: glow-drift 8s ease-in-out infinite alternate;
}
@keyframes glow-drift {
  from { transform: translate(0, 0) scale(1); }
  to { transform: translate(-60px, 40px) scale(1.15); }
}
.hero-glow-2 {
  position: absolute; bottom: -50px; left: -80px;
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(26,92,107,0.15) 0%, transparent 70%);
  border-radius: 50%;
  animation: glow-drift-2 10s ease-in-out infinite alternate;
}
@keyframes glow-drift-2 {
  from { transform: translate(0, 0) scale(1); }
  to { transform: translate(40px, -30px) scale(1.1); }
}
.hero-content {
  position: relative; z-index: 2;
  max-width: 1280px; margin: 0 auto;
  padding: 120px 40px 100px;
}
.hero-eyebrow {
  font-family: var(--mono); font-size: 12px; letter-spacing: 0.25em;
  color: var(--gold); text-transform: uppercase; margin-bottom: 24px;
  opacity: 0; animation: fade-up 0.8s ease forwards 0.2s;
}
.hero h1 {
  font-family: var(--serif); font-size: clamp(38px, 5vw, 64px);
  font-weight: 400; line-height: 1.1; color: #fff;
  max-width: 800px; margin-bottom: 28px;
  opacity: 0; animation: fade-up 0.8s ease forwards 0.4s;
}
.hero h1 em {
  font-style: italic; color: var(--gold-light);
  background: linear-gradient(135deg, var(--gold-light), var(--gold));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.hero-sub {
  font-family: var(--sans); font-size: 17px; line-height: 1.7;
  color: rgba(255,255,255,0.6); max-width: 600px;
  opacity: 0; animation: fade-up 0.8s ease forwards 0.6s;
}
@keyframes fade-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

/* Hero quote */
.hero-quote {
  max-width: 680px; margin-top: 48px;
  padding: 28px 0 0 32px;
  border-left: 3px solid var(--gold);
  opacity: 0; animation: fade-up 0.8s ease forwards 0.8s;
}
.hero-quote blockquote {
  font-family: var(--serif); font-size: 20px; font-style: italic;
  line-height: 1.6; color: rgba(255,255,255,0.55);
}
.hero-quote cite {
  display: block; margin-top: 12px;
  font-family: var(--mono); font-size: 10px; font-style: normal;
  letter-spacing: 0.15em; color: var(--gold); text-transform: uppercase;
}

/* Stats bar */
.hero-stats {
  position: relative; z-index: 2;
  max-width: 1280px; margin: -50px auto 0; padding: 0 40px;
}
.hero-stats-inner {
  display: grid; grid-template-columns: repeat(3, 1fr);
  background: rgba(27, 42, 64, 0.95);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(184,150,46,0.2);
  border-radius: 2px; overflow: hidden;
}
.stat-card {
  padding: 32px 24px; text-align: center; position: relative;
}
.stat-card:not(:last-child)::after {
  content: '';
  position: absolute; right: 0; top: 20%; height: 60%; width: 1px;
  background: linear-gradient(to bottom, transparent, rgba(184,150,46,0.3), transparent);
}
.stat-number {
  font-family: var(--serif); font-size: 36px; font-weight: 700;
  background: linear-gradient(135deg, var(--gold-light), var(--gold));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.stat-label {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.15em;
  color: rgba(255,255,255,0.55); text-transform: uppercase; margin-top: 6px;
}

/* ============================================================
   CARD GRID — Leadership cards
   ============================================================ */
.grid-section {
  padding: var(--section-pad) 40px;
  max-width: 1280px; margin: 0 auto;
}
.grid-intro {
  max-width: 680px; margin-bottom: 48px;
}
.grid-intro p {
  font-size: 16px; line-height: 1.8; color: var(--muted); max-width: 600px;
}

/* Board roster */
.board-works {
  max-width: 680px; margin-bottom: 56px;
}
.board-works p {
  font-size: 16px; line-height: 1.8; color: var(--muted); margin-bottom: 16px;
}
.board-works p:last-child { margin-bottom: 0; }
.roster-eyebrow {
  font-family: var(--mono); font-size: 11px; letter-spacing: 0.25em;
  text-transform: uppercase; color: var(--gold-accessible); margin-bottom: 20px;
}
.chair-block { margin-bottom: 56px; }
.chair-card {
  background: #fff; border: 1px solid rgba(10,10,15,0.06);
  border-top: 3px solid var(--slate);
  padding: 32px 28px; max-width: 680px;
}
.chair-name {
  font-family: var(--serif); font-size: 30px; font-weight: 600;
  color: var(--ink); line-height: 1.2; margin: 6px 0 8px;
}
.members-block { margin-bottom: 64px; }
.roster-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 20px;
}
.roster-card {
  background: #fff; border: 1px solid rgba(10,10,15,0.06);
  border-top: 3px solid var(--slate);
  padding: 28px 24px;
}
.roster-company {
  font-family: var(--mono); font-size: 10px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; color: var(--slate);
}
.roster-name {
  font-family: var(--serif); font-size: 22px; font-weight: 600;
  color: var(--ink); line-height: 1.2; margin: 6px 0 6px;
}
.roster-title {
  font-size: 14px; line-height: 1.5; color: var(--muted);
}
.join-board {
  background: rgba(44,62,90,0.04); border: 1px solid rgba(10,10,15,0.04);
  padding: 48px; text-align: center;
}
.join-board-lede {
  font-family: var(--serif); font-size: 22px; line-height: 1.5;
  color: var(--slate); max-width: 640px; margin: 0 auto 28px;
}
.card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
  gap: 20px;
}

.card {
  background: #fff;
  border: 1px solid rgba(10,10,15,0.06);
  padding: 32px 28px;
  cursor: pointer;
  position: relative;
  transition: transform 0.4s, box-shadow 0.4s;
}
.card:hover {
  transform: translateY(-3px);
  box-shadow: 0 16px 48px rgba(10,10,15,0.06);
}
.card.expanded {
  box-shadow: 0 20px 60px rgba(10,10,15,0.1);
  transform: translateY(-3px);
}
/* Color-coded top bar — cycles through palette */
.card::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 3px;
}
.card[data-accent="slate"]::before { background: linear-gradient(90deg, var(--slate), var(--slate-mid)); }
.card[data-accent="teal"]::before { background: linear-gradient(90deg, var(--teal), var(--teal-soft)); }
.card[data-accent="warm"]::before { background: linear-gradient(90deg, var(--warm), var(--warm-light)); }
.card[data-accent="gold"]::before { background: linear-gradient(90deg, var(--gold), var(--gold-light)); }
.card[data-accent="sage"]::before { background: linear-gradient(90deg, var(--sage), var(--sage-light)); }
.card[data-accent="ink"]::before { background: linear-gradient(90deg, var(--ink), var(--slate)); }

.card-header {
  display: flex; align-items: center; gap: 14px; margin-bottom: 12px;
}
.card-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-family: var(--mono);
  font-size: 13px; font-weight: 600; letter-spacing: 0.05em;
  flex-shrink: 0;
}
.card[data-accent="slate"] .card-avatar { background: var(--slate); }
.card[data-accent="teal"] .card-avatar { background: var(--teal); }
.card[data-accent="warm"] .card-avatar { background: var(--warm); }
.card[data-accent="gold"] .card-avatar { background: var(--gold); }
.card[data-accent="sage"] .card-avatar { background: var(--sage); }
.card[data-accent="ink"] .card-avatar { background: var(--ink-soft); }

.card-name {
  font-family: var(--serif); font-size: 20px; font-weight: 600;
  color: var(--ink); line-height: 1.2;
}
.card-org {
  font-family: var(--mono); font-size: 10px; font-weight: 500;
  letter-spacing: 0.1em; text-transform: uppercase; margin-top: 3px;
}
.card[data-accent="slate"] .card-org { color: var(--slate); }
.card[data-accent="teal"] .card-org { color: var(--teal); }
.card[data-accent="warm"] .card-org { color: var(--warm); }
.card[data-accent="gold"] .card-org { color: var(--gold-accessible-light); }
.card[data-accent="sage"] .card-org { color: var(--sage); }
.card[data-accent="ink"] .card-org { color: var(--ink-soft); }

.card-title {
  font-size: 14px; line-height: 1.5; color: var(--muted);
}
.card-affiliation {
  font-family: var(--mono); font-size: 10px; letter-spacing: 0.08em;
  color: var(--muted); margin-top: 6px;
}
.card-chevron {
  position: absolute; top: 32px; right: 24px;
  font-size: 14px; color: rgba(10,10,15,0.15);
  transition: transform 0.3s, color 0.3s;
}
.card.expanded .card-chevron {
  transform: rotate(180deg); color: var(--gold);
}
.card-bio {
