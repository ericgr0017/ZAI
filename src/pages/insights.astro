---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/ui/SectionHero.astro';

const LIBRARY_URL = 'https://insights.zaiinstitute.ai';
---

<BaseLayout
  title="Published research"
  description="Free published research from ZAI Institute on enterprise AI: readiness, the skills gap, and agent governance. Drawn from interviews and surveys with senior operators."
>
  <SectionHero
    eyebrow="Insights"
    title="The gap, measured."
    lede="Everyone talks about what AI will do. We study what it actually delivers. These reports are free to read, drawn from structured interviews and surveys with senior operators across the institute's executive community."
  />

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">

      <ul class="divide-y divide-light-border/60 list-none p-0 m-0" role="list">

        <li class="py-8 md:py-12 first:pt-0">
          <article class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-3">
              <div class="font-mono text-xs uppercase tracking-wide-cap text-muted">Report</div>
              <div class="font-mono text-xs text-muted mt-1">March 2026</div>
              <div class="font-mono text-xs text-muted mt-1">14 min read</div>
            </div>
            <div class="md:col-span-9">
              <h2 class="font-display text-h2 text-ink">The AI readiness gap</h2>
              <p class="mt-4 text-body text-ink/90 max-w-prose-wide">
                How Fortune 500 organizations are translating AI awareness into organizational
                capability, and where the gap lives between executive intent and operator readiness.
              </p>
              <a
                href="/insights/ai-readiness-gap-2026-updated.html"
                class="inline-block mt-5 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink"
              >
                Read the report &rsaquo;
              </a>
            </div>
          </article>
        </li>

        <li class="py-8 md:py-12">
          <article class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-3">
              <div class="font-mono text-xs uppercase tracking-wide-cap text-muted">Report</div>
              <div class="font-mono text-xs text-muted mt-1">April 2026</div>
              <div class="font-mono text-xs text-muted mt-1">12 min read</div>
            </div>
            <div class="md:col-span-9">
              <h2 class="font-display text-h2 text-ink">The AI skills gap</h2>
              <p class="mt-4 text-body text-ink/90 max-w-prose-wide">
                What the workforce needs to learn next, with a finding that surprised the
                researchers: forty-seven percent of leaders cite undefined AI strategy, not a skills
                shortage, as their biggest barrier to results.
              </p>
              <a
                href="/insights/ai-skills-gap-2026.html"
                class="inline-block mt-5 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink"
              >
                Read the report &rsaquo;
              </a>
            </div>
          </article>
        </li>

        <li class="py-8 md:py-12">
          <article class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-3">
              <div class="font-mono text-xs uppercase tracking-wide-cap text-muted">Report</div>
              <div class="font-mono text-xs text-muted mt-1">May 2026</div>
              <div class="font-mono text-xs text-muted mt-1">10 min read</div>
            </div>
            <div class="md:col-span-9">
              <h2 class="font-display text-h2 text-ink">The agent readiness gap</h2>
              <p class="mt-4 text-body text-ink/90 max-w-prose-wide">
                Why enterprises are deploying AI agents faster than they can govern them. Sixty-nine
                percent are piloting or in production. Thirty-nine percent have a formal oversight
                policy. The gap is the work of the next eighteen months.
              </p>
              <a
                href="/insights/agent-readiness-gap-2026.html"
                class="inline-block mt-5 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink"
              >
                Read the report &rsaquo;
              </a>
            </div>
          </article>
        </li>

        <li class="py-8 md:py-12">
          <article class="grid grid-cols-1 md:grid-cols-12 gap-6">
            <div class="md:col-span-3">
              <div class="font-mono text-xs uppercase tracking-wide-cap text-gold-deep">Open survey</div>
              <div class="font-mono text-xs text-muted mt-1">10 questions &middot; ~4 min</div>
            </div>
            <div class="md:col-span-9">
              <h2 class="font-display text-h2 text-ink">Contribute to the research</h2>
              <p class="mt-4 text-body text-ink/90 max-w-prose-wide">
                The research is built from operators like you. Add your view on how organizations
                oversee, control, and answer for the AI they have put to work. Ten questions,
                anonymous, feeding the next report.
              </p>
              <a
                href="/governance-accountability-survey/"
                class="inline-block mt-5 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink"
              >
                Take the survey &rsaquo;
              </a>
            </div>
          </article>
        </li>

      </ul>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-prose-wide">
        <div class="eyebrow mb-6">Intelligence Library</div>
        <h2 class="font-display text-h2 text-paper">The full library lives here.</h2>
        <p class="mt-6 text-body-lg text-paper/85 max-w-prose-narrow">
          These reports are the public face of a larger body of work. The Intelligence Library holds
          the member briefs, the benchmarks, and the monthly Executive Intelligence Report, organized
          by topic. Executive summaries are free. The full signals and prevalence sit behind
          membership.
        </p>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href={LIBRARY_URL} class="btn btn-primary">Go to the Intelligence Library</a>
          <a href={`${LIBRARY_URL}/tiers`} class="btn btn-ghost-light">See membership</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
