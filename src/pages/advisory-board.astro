---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/ui/SectionHero.astro';
import advisors from '../data/advisors.json';

const { chair, members } = advisors;
const totalCount = members.length + 1;
---

<BaseLayout
  title="Advisory board"
  description="The ZAI Institute Advisory Board: senior operators from across the Fortune 500, at the inner circle of a broader network of 50,000 executives across 500+ companies."
>
  <SectionHero
    eyebrow="Advisory board"
    title="The inner circle of a wider network."
    lede="The Advisory Board sits at the center of a broader network of fifty thousand senior operators across five hundred companies. Members convene quarterly, contribute throughout the year, and bring the voice of the working executive into every program and research finding the institute produces."
  />

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-prose-wide mb-16">
        <h2 class="eyebrow eyebrow-on-light mb-4">How the board works</h2>
        <div class="space-y-4 text-body text-ink/90">
          <p>
            The Advisory Board meets quarterly and contributes throughout the year through
            curriculum review, capstone evaluations, panel participation, and informal peer
            briefings with cohort participants. Members are senior operators whose day-to-day work
            intersects the questions the institute's research and programs address.
          </p>
          <p>
            The Board does not approve research findings or program syllabi. It informs them.
          </p>
        </div>
      </div>

      <hr class="rule-gold opacity-60 mb-16" />

      <div class="mb-16">
        <h2 class="eyebrow eyebrow-on-light mb-8">Chair</h2>
        <article class="border-t-2 border-rule pt-6 max-w-prose-wide">
          <div class="font-mono text-xs uppercase tracking-wide-cap text-muted mb-3">{chair.company}</div>
          <h3 class="font-display text-3xl text-ink mb-2">{chair.name}</h3>
          <p class="text-body text-ink/90">{chair.title}</p>
        </article>
      </div>

      <hr class="rule-muted mb-16" />

      <div>
        <h2 class="eyebrow eyebrow-on-light mb-8">Members</h2>
        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-10 gap-y-10 list-none p-0 m-0">
          {
            members.map((m) => (
              <li>
                <article class="border-t border-light-border pt-5 h-full">
                  <div class="font-mono text-xs uppercase tracking-wide-cap text-muted mb-3">
                    {m.company}
                  </div>
                  <h3 class="font-display text-xl text-ink mb-2 leading-tight">{m.name}</h3>
                  <p class="text-sm text-ink/85 leading-snug">{m.title}</p>
                </article>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </section>

  <section class="bg-ink-soft text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <h2 class="eyebrow mb-8">The wider network</h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10">
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">{totalCount}</div>
          <div class="mt-3 text-sm text-paper/80">Named advisors</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">50,000+</div>
          <div class="mt-3 text-sm text-paper/80">Executives in the wider network</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">500+</div>
          <div class="mt-3 text-sm text-paper/80">Companies represented</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">30+</div>
          <div class="mt-3 text-sm text-paper/80">University partners served</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
