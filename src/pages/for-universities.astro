---
import BaseLayout from '@layouts/BaseLayout.astro';
import SectionHero from '@components/ui/SectionHero.astro';
import Placeholder from '@components/ui/Placeholder.astro';
---

<BaseLayout
  title="For universities"
  description="ZAI Institute partners with universities to launch AI executive education programs in 30 days. Turnkey programs, faculty enablement, and access to a network of 50,000 senior operators."
>
  <SectionHero
    eyebrow="For universities"
    title="AI programs your institution can launch in 30 days."
    lede="Placeholder lede for university leaders. Position the 30-day deployment model, no new hires required."
  />

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24 space-y-16">
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">The 30-day model</div>
        <Placeholder label="Explain the 30-day deployment. What happens in each phase, what the institution provides, what ZAI provides." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Existing programs</div>
        <Placeholder label="Catalog the currently available program tracks (Strategy for Senior Leaders, AI for Operators, etc). Each with name, length, audience." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Custom curriculum</div>
        <Placeholder label="Describe the custom build process: when a university wants a program tailored to their region, sector, or partnership pipeline." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Faculty enablement</div>
        <Placeholder label="How ZAI trains faculty to teach AI content, what assets and ongoing support are provided." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Network access for students</div>
        <Placeholder label="How program participants gain access to the broader 50K-executive network. Outcomes and frequency." />
      </div>
      <hr class="rule-muted" />
      <div>
        <div class="eyebrow eyebrow-on-light mb-4">Revenue model</div>
        <Placeholder label="Frame the partnership as revenue-generating, not cost. What a university typically nets per cohort." />
      </div>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-prose-wide">
        <div class="eyebrow mb-6">Next step</div>
        <h2 class="font-display text-h2 text-paper">
          A discovery conversation.
        </h2>
        <p class="mt-6 text-body-lg text-paper/85">
          <Placeholder label="One sentence framing the discovery call for university leaders." />
        </p>
        <div class="mt-10">
          <a href="/contact" class="btn btn-primary">Request a discovery conversation</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
