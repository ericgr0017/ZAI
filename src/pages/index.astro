---
import BaseLayout from '@layouts/BaseLayout.astro';
import Placeholder from '@components/ui/Placeholder.astro';
---

<BaseLayout
  title="ZAI Institute"
  description="ZAI Institute is the institution behind the institutions. We partner with universities and enterprises to launch AI executive education programs in 30 days."
>
  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-24 md:py-36">
      <div class="max-w-prose-wide">
        <div class="eyebrow mb-6">ZAI Institute</div>
        <h1 class="font-display text-h1 text-paper">
          The institution behind the institutions.
        </h1>
        <div class="mt-8 max-w-prose-narrow">
          <Placeholder label="Homepage hero lede. Two to three sentences positioning ZAI Institute across Programs, Research, and Network. Copy from Ian." />
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="eyebrow eyebrow-on-light mb-6">What we do</div>
      <h2 class="font-display text-h2 text-muted max-w-prose-wide opacity-70">
        [Placeholder: section title introducing the three product lines at equal weight]
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12 mt-12">
        <article>
          <div class="eyebrow eyebrow-on-light mb-3">01 &middot; Programs</div>
          <h3 class="font-display text-2xl text-muted mb-3 opacity-70">
            [Placeholder: Programs card title]
          </h3>
          <Placeholder label="Programs card body. 30-day deployment, university partnerships, faculty enablement, custom curriculum." />
          <a href="/for-universities" class="inline-block mt-4 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink">
            For universities &rsaquo;
          </a>
          <span class="mx-2 text-muted">/</span>
          <a href="/for-organizations" class="inline-block mt-4 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink">
            For organizations &rsaquo;
          </a>
        </article>

        <article>
          <div class="eyebrow eyebrow-on-light mb-3">02 &middot; Research</div>
          <h3 class="font-display text-2xl text-muted mb-3 opacity-70">
            [Placeholder: Research card title]
          </h3>
          <Placeholder label="Research card body. Commercial engagements, subscription intelligence, published reports. Methodology and corpus summary." />
          <a href="/research" class="inline-block mt-4 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink">
            Research engagements &rsaquo;
          </a>
        </article>

        <article>
          <div class="eyebrow eyebrow-on-light mb-3">03 &middot; Network</div>
          <h3 class="font-display text-2xl text-muted mb-3 opacity-70">
            [Placeholder: Network card title]
          </h3>
          <Placeholder label="Network card body. Advisory Board of 25, broader network of 50,000+ executives across 500+ companies." />
          <a href="/advisory-board" class="inline-block mt-4 text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink">
            Advisory board &rsaquo;
          </a>
        </article>
      </div>
    </div>
  </section>

  <section class="bg-ink-soft text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="eyebrow mb-6">By the numbers</div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-10 mt-8">
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">60+</div>
          <div class="mt-3 text-sm text-paper/80">University partners</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">50,000+</div>
          <div class="mt-3 text-sm text-paper/80">Executives in the network</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">500+</div>
          <div class="mt-3 text-sm text-paper/80">Companies represented</div>
        </div>
        <div>
          <div class="font-mono text-4xl md:text-5xl text-gold">25</div>
          <div class="mt-3 text-sm text-paper/80">Advisory board members</div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper text-ink">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-10">
        <div class="md:col-span-5">
          <div class="eyebrow eyebrow-on-light mb-6">Who we serve</div>
          <h2 class="font-display text-h2 text-muted opacity-70">
            [Placeholder: who we serve section title]
          </h2>
        </div>
        <div class="md:col-span-7 space-y-8">
          <div>
            <h3 class="font-sans text-lg font-bold text-ink mb-2">University leaders</h3>
            <Placeholder label="Two sentences. Presidents, provosts, deans of continuing education." />
          </div>
          <hr class="rule-muted" />
          <div>
            <h3 class="font-sans text-lg font-bold text-ink mb-2">Enterprise leaders</h3>
            <Placeholder label="Two sentences. Chief learning officers, chief transformation officers, heads of strategy." />
          </div>
          <hr class="rule-muted" />
          <div>
            <h3 class="font-sans text-lg font-bold text-ink mb-2">Senior executives</h3>
            <Placeholder label="Two sentences. Members and prospective members of the advisory network." />
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper text-ink border-t border-light-border">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="flex items-baseline justify-between mb-10">
        <div>
          <div class="eyebrow eyebrow-on-light mb-3">Recent research</div>
          <h2 class="font-display text-h2 text-ink">From the institute.</h2>
        </div>
        <a href="/insights" class="hidden md:inline-block text-sm font-medium text-gold-deep border-b border-gold pb-0.5 hover:text-ink">
          All insights &rsaquo;
        </a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10">
        <article class="border-t-2 border-rule pt-5">
          <div class="font-mono text-xs uppercase tracking-wide-cap text-muted mb-3">Report &middot; 2026</div>
          <h3 class="font-display text-xl text-ink mb-3">AI readiness gap</h3>
          <Placeholder label="One-sentence summary of the AI Readiness Gap report." />
        </article>
        <article class="border-t-2 border-rule pt-5">
          <div class="font-mono text-xs uppercase tracking-wide-cap text-muted mb-3">Report &middot; 2026</div>
          <h3 class="font-display text-xl text-ink mb-3">AI skills gap</h3>
          <Placeholder label="One-sentence summary of the AI Skills Gap report." />
        </article>
        <article class="border-t-2 border-rule pt-5">
          <div class="font-mono text-xs uppercase tracking-wide-cap text-muted mb-3">Forthcoming</div>
          <h3 class="font-display text-xl text-ink mb-3">Agent readiness gap</h3>
          <Placeholder label="One-sentence summary of the forthcoming Agent Readiness Gap report." />
        </article>
      </div>
    </div>
  </section>

  <section class="bg-ink text-paper">
    <div class="max-w-7xl mx-auto px-6 lg:px-8 py-20 md:py-24">
      <div class="max-w-prose-wide">
        <div class="eyebrow mb-6">Start a conversation</div>
        <h2 class="font-display text-h2 text-paper/60">
          [Placeholder: closing CTA section headline]
        </h2>
        <div class="mt-6 max-w-prose-narrow">
          <Placeholder label="Closing CTA section body, one sentence." />
        </div>
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="btn btn-primary">Request a conversation</a>
          <a href="/research" class="btn btn-ghost-light">Read the research</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
